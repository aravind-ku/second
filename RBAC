openssl genrsa -out vindu.key 2048
openssl req -new -key vindu.key -out vindu,csr -subj "/CN=vindu/O=group1"
openssl x509 -req -in vindu.csr \
-CA ~/.minikube/ca.crt \
-CAkey ~/.minikube/ca.key \
-CAcreateserial \
-out vindu.crt \
-days 500

kubectl config set-context my-context --cluster=minikube --user=vindu
kubectl config view
kubectl config use-context my-context

